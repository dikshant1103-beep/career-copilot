# ============================================================
# Career Copilot - environment configuration
# ============================================================
# Copy to `.env` and fill in values:
#     cp .env.example .env
# ============================================================

# ---- Path to the sibling career_ai_assistant project ----
# (Defaults to ~/Desktop/career_ai_assistant if left empty.)
CAREER_AI_PATH=

# ---- Anthropic Claude API ----
# Get a key at https://console.anthropic.com/settings/keys
# (This is also read by career_ai_assistant — set it here OR in that project's .env)
ANTHROPIC_API_KEY=sk-ant-replace-me
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Adzuna job search (free) ----
# Sign up at https://developer.adzuna.com/  →  My Apps  →  copy app_id + app_key
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- Backend server ----
COPILOT_HOST=127.0.0.1
COPILOT_PORT=8765
