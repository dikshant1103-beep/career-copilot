{
  "name": "career-copilot-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Electron + React + Vite UI for the Career Copilot",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:5174 && tsc -p electron/tsconfig.json && cross-env COPILOT_DEV=1 electron .",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "start": "tsc -p electron/tsconfig.json && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
